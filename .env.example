# FinanceAgent 环境变量示例
APP_ENV=dev
LOG_LEVEL=INFO
REPORT_OUTPUT_DIR=reports_output
RAW_DATA_DIR=data/raw
KNOWLEDGE_BASE_DIR=data/knowledge_base
SEC_USER_AGENT=FinanceAgent/1.0 your_email@example.com
VECTOR_STORE_PROVIDER=chroma
VECTOR_COLLECTION=finance_docs
CHROMA_PERSIST_DIR=.chroma
TOP_K=5
BM25_WEIGHT=0.4
VECTOR_WEIGHT=0.6
RERANK_TOP_N=5
ENABLE_LANGGRAPH=true

# RAG 向量化（默认 hash；建议本地 bge/e5）
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=auto
EMBEDDING_BATCH_SIZE=16
EMBEDDING_NORMALIZE=true

# RAG 重排（默认 simple；建议本地 cross-encoder）
RERANKER_PROVIDER=simple
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=auto
RERANKER_BATCH_SIZE=16

# 通用 ReAct + MCP（四个专家 Agent 统一开关）
REACT_MCP_ENABLED=false
REACT_MCP_MAX_STEPS=4

# NewsAgent ReAct + MCP（兼容开关）
NEWS_REACT_MCP_ENABLED=false
NEWS_REACT_MAX_STEPS=4

# LLM（OpenAI-Compatible）：可接百炼/ OpenAI / 其他兼容接口
LLM_ENABLED=false
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# 可使用 LLM_API_KEY，或直接用 DASHSCOPE_API_KEY / OPENAI_API_KEY
LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=45
LLM_MAX_TOKENS=1400
LLM_JSON_RETRY_MAX=2
LLM_TRACE_ENABLED=true
LLM_TRACE_FILE=logs/llm_trace.jsonl
LLM_TRACE_MAX_CHARS=6000

# 本地新闻情感/风险模型（Qwen + LoRA）
NEWS_MODEL_ENABLED=false
NEWS_MODEL_BASE=Qwen/Qwen2.5-1.5B-Instruct
NEWS_MODEL_ADAPTER=models/news_qwen_lora
NEWS_MODEL_DEVICE=auto
NEWS_MODEL_MAX_NEW_TOKENS=96
